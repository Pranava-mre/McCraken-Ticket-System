# Flask settings
SECRET_KEY=change-this-secret-key

# PostgreSQL (Azure) - Option A: single URL (recommended)
# Example:
# DATABASE_URL=postgresql://username:password@your-server.postgres.database.azure.com:5432/your_database?sslmode=require
DATABASE_URL=

# PostgreSQL (Azure) - Option B: separate values (used if DATABASE_URL is empty)
PGHOST=tktsys-db.postgres.database.azure.com
PGPORT=5432
PGDATABASE=postgres
PGUSER=tktsys_pgdb
PGPASSWORD=Mccraken_database
PGSSLMODE=require

# Optional jobs cache source settings
AUTO_REFRESH_JOBS_ON_STARTUP=1
JOBS_CSV_PATH=data/jobs.csv
JOBS_CSV_URL=https://drive.google.com/file/d/1Eh6-Yzyqh7htcU2SJjeyT3i9TdcWxpHI/view?usp=sharing
REMOTE_SQL_ODBC_CONNECTION_STRING=
